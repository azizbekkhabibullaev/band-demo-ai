{
  "name": "@bank-chatbot/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "find tests -name '*.test.ts' | grep -v 'db/migrate' | sort | { cat; echo 'tests/db/migrate.test.ts'; } | xargs node --test --test-concurrency=1 --test-reporter=spec --import tsx/esm",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@bank-chatbot/shared": "0.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.0",
    "pg": "^8.12.0",
    "tsx": "^4.16.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.5.0"
  }
}
